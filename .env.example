# API 설정
EXPO_PUBLIC_API_URL=https://dev-api.un-plan.com/
OPENAPI_SPEC_URL=https://dev-api.un-plan.com/v3/api-docs

# Kakao OAuth 설정
# Native App Key만 앱에 포함합니다. Admin Key, Client Secret은 절대 추가하지 마세요.
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=

# Google OAuth 설정
# Client ID는 공개 식별자입니다. Client Secret은 앱에 절대 추가하지 마세요.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# 앱 환경 (development | staging | production)
EXPO_PUBLIC_APP_ENV=development
